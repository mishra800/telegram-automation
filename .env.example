# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username
TELEGRAM_GROUP_ID=-100xxxxxxxxxx

# AI Content Generation
USE_GEMINI=false
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration (fallback)
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434

# Stable Diffusion Configuration
SD_MODEL=stabilityai/stable-diffusion-2-1
USE_LOCAL_SD=true

# Scheduling Configuration
TIMEZONE=UTC
GROWTH_MODE=true
MIN_POST_INTERVAL_MINUTES=30

# Dynamic posting frequency (GROWTH_MODE=true)
FOLLOWER_THRESHOLD_LOW=1000
FOLLOWER_THRESHOLD_HIGH=10000
POSTS_PER_DAY_LOW=18
POSTS_PER_DAY_MEDIUM=10
POSTS_PER_DAY_HIGH=6

# Analytics Configuration
ANALYTICS_CHECK_DELAY=24

# Dashboard Configuration
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
